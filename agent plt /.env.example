# Orynval — monday.com integration (server-side only; never exposed to the browser).
# Copy to ".env" for local `netlify dev`, and set the same vars in the Netlify dashboard.

# Required
MONDAY_API_TOKEN=your_monday_api_token_here
MONDAY_BOARD_ID=1234567890

# Optional — drop new items into a specific group
# MONDAY_GROUP_ID=topics

# Optional — map fields to real board columns (get column ids from the board).
# If MONDAY_COL_DETAILS is set, company/industry/notes are written there as text.
# MONDAY_COL_EMAIL=email
# MONDAY_COL_DETAILS=long_text
# MONDAY_COL_STATUS=status
# MONDAY_STATUS_LABEL=New demo request
# MONDAY_COL_SOURCE=text
# MONDAY_COL_CREATED_AT=date4
