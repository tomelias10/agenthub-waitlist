# monday.com API credentials (server-side only — never expose to client)
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=5096679020

# Optional: pin a specific group in the board (leave empty to use first group)
MONDAY_GROUP_ID=

# Column IDs — discover with `npm run debug:board` then paste them here.
# Leave any unused mapping blank and that field will be skipped.
MONDAY_COL_EMAIL=
MONDAY_COL_PHONE=
MONDAY_COL_MESSAGE=
MONDAY_COL_SOURCE=
MONDAY_COL_STATUS=
MONDAY_COL_CREATED_AT=

# Status label written to MONDAY_COL_STATUS
MONDAY_STATUS_LABEL=New Lead

# Local Express server only (Netlify ignores this)
PORT=3000

# If non-empty, /api/board-debug requires ?key=<value>
DEBUG_KEY=
